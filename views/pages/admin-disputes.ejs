<%- include('../partials/header') %>

    <div class="container-fluid p-0">
        <div class="row g-0">
            <!-- Sidebar -->
            <div class="col-md-2 admin-sidebar d-none d-md-block">
                <div class="sidebar-header">Main</div>
                <a href="/admin" class="nav-link"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a href="/admin/users" class="nav-link"><i class="bi bi-people"></i> Users</a>
                <a href="/admin/bookings" class="nav-link"><i class="bi bi-calendar-check"></i> Bookings</a>
                <div class="sidebar-header">Management</div>
                <a href="/admin/disputes" class="nav-link active"><i class="bi bi-exclamation-triangle"></i>
                    Disputes</a>
                <a href="/admin/commissions" class="nav-link"><i class="bi bi-percent"></i> Commissions</a>
                <div class="sidebar-header">Account</div>
                <a href="/auth/logout" class="nav-link"><i class="bi bi-box-arrow-left"></i> Logout</a>
            </div>

            <!-- Main -->
            <div class="col-md-10 p-4">
                <div class="mb-4">
                    <h3 class="fw-bold mb-0"><i class="bi bi-exclamation-triangle text-warning"></i> Dispute Management
                    </h3>
                    <p class="text-muted">
                        <%= disputes.length %> total disputes
                    </p>
                </div>

                <% if (disputes.length> 0) { %>
                    <% disputes.forEach(d=> { %>
                        <div class="card p-4 mb-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">Dispute #<%= d.id.substring(0,8) %>
                                    </h6>
                                    <small class="text-muted">Raised by: <strong>
                                            <%= d.raiser_name %>
                                                <%= d.raiser_last || '' %>
                                        </strong> (<%= d.raiser_email %>)</small>
                                </div>
                                <span class="badge-status badge-<%= d.status %>">
                                    <%= d.status %>
                                </span>
                            </div>

                            <div class="row mt-3">
                                <div class="col-md-4">
                                    <p class="mb-1"><strong>Booking Amount:</strong> NPR <%=
                                            Number(d.total_amount).toLocaleString() %>
                                    </p>
                                    <p class="mb-0"><strong>Event Date:</strong>
                                        <%= d.event_date ? new Date(d.event_date).toLocaleDateString() : '—' %>
                                    </p>
                                </div>
                                <div class="col-md-8">
                                    <p class="mb-1"><strong>Reason:</strong></p>
                                    <p class="mb-0">
                                        <%= d.reason %>
                                    </p>
                                </div>
                            </div>

                            <% if (d.resolution) { %>
                                <div class="alert alert-success mt-3 mb-0">
                                    <strong>Resolution:</strong>
                                    <%= d.resolution %>
                                        <br><small>Resolved on: <%= new Date(d.resolved_at).toLocaleDateString() %>
                                                </small>
                                </div>
                                <% } %>

                                    <% if (d.status==='open' || d.status==='under_review' ) { %>
                                        <form action="/admin/disputes/<%= d.id %>?_method=PUT" method="POST"
                                            class="mt-3 p-3 bg-light rounded">
                                            <div class="row g-3">
                                                <div class="col-md-3">
                                                    <select name="status" class="form-select" required>
                                                        <option value="under_review">Under Review</option>
                                                        <option value="resolved">Resolved</option>
                                                        <option value="dismissed">Dismissed</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-7">
                                                    <input type="text" name="resolution" class="form-control"
                                                        placeholder="Resolution notes..." required>
                                                </div>
                                                <div class="col-md-2">
                                                    <button class="btn btn-primary w-100">Submit</button>
                                                </div>
                                            </div>
                                        </form>
                                        <% } %>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="empty-state"><i class="bi bi-check-circle"></i>
                                    <p>No disputes. All clear!</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/tail') %>