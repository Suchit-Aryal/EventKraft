<%- include('../partials/header') %>
    <div class="container py-5">
        <h2>My Bookings</h2>
        <% if (bookings && bookings.length> 0) { %>
            <table class="table table-striped mt-3">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Status</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach(b=> { %>
                        <tr>
                            <td>
                                <%= b.id.substring(0,8) %>...
                            </td>
                            <td><span class="badge bg-info">
                                    <%= b.status %>
                                </span></td>
                            <td>NPR <%= b.total_amount %>
                            </td>
                            <td>
                                <%= b.event_date || 'TBD' %>
                            </td>
                            <td><a href="/bookings/<%= b.id %>" class="btn btn-sm btn-outline-primary">View</a></td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% } else { %>
                <p class="text-muted mt-3">No bookings yet.</p>
                <% } %>
    </div>
    <%- include('../partials/tail') %>