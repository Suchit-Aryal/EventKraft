<%- include('../partials/header') %>
    <div class="container py-5">
        <h2>Browse Services</h2>
        <p class="text-muted">Discover premium event service providers.</p>
        <div class="row g-4 mt-3">
            <% if (gigs && gigs.length> 0) { %>
                <% gigs.forEach(gig=> { %>
                    <div class="col-md-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= gig.title %>
                                </h5>
                                <span class="badge bg-secondary mb-2">
                                    <%= gig.category_name || 'Uncategorized' %>
                                </span>
                                <p class="card-text text-muted">
                                    <%= gig.description ? gig.description.substring(0, 120) + '...' : '' %>
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-success fw-bold">From NPR <%= gig.starting_price %></span>
                                    <a href="/gigs/<%= gig.id %>" class="btn btn-sm btn-outline-primary">View</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center text-muted">
                                <p>No services available yet. Check back later!</p>
                            </div>
                            <% } %>
        </div>
    </div>
    <%- include('../partials/tail') %>