<%- include('../partials/header') %>

<div class="ek-auth-split">
    <!-- Form Panel -->
    <div class="ek-auth-form">
        <div style="width:100%;max-width:460px">
            <a href="/" class="d-lg-none d-flex align-items-center gap-2 mb-4 text-decoration-none">
                <i class="bi bi-stars fs-5" style="color:var(--ek-maroon)"></i>
                <span class="font-display fs-5 fw-semibold">EventKraft</span>
            </a>

            <h1 class="font-display fs-2 fw-semibold">Create your account</h1>
            <p class="text-muted small mt-1">Choose how you'll use EventKraft.</p>

            <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
                <a href="/auth/google" class="btn btn-outline-dark w-100 d-flex align-items-center justify-content-center gap-2 mt-3" style="border-radius:8px;padding:10px">
                    <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
                    Sign up with Google
                </a>
                <div class="d-flex align-items-center gap-3 my-3">
                    <hr class="flex-grow-1"><span class="text-muted small">or register with email</span>
                    <hr class="flex-grow-1">
                </div>
            <% } %>

            <!-- Role Selection -->
            <div class="row g-2 mt-2 mb-4">
                <div class="col-6">
                    <div class="ek-role-card active" id="roleCustomer" onclick="selectRole('customer')">
                        <i class="bi bi-bag fs-5 d-block mb-1" style="color:var(--ek-maroon)"></i>
                        <p class="fw-semibold small mb-0">I'm a Customer</p>
                        <p class="text-muted" style="font-size:.75rem;margin:0">Looking for services</p>
                    </div>
                </div>
                <div class="col-6">
                    <div class="ek-role-card" id="roleWorker" onclick="selectRole('worker')">
                        <i class="bi bi-tools fs-5 d-block mb-1" style="color:var(--ek-maroon)"></i>
                        <p class="fw-semibold small mb-0">I'm a Worker</p>
                        <p class="text-muted" style="font-size:.75rem;margin:0">I provide services</p>
                    </div>
                </div>
            </div>

            <form action="/auth/register" method="POST" class="ek-form">
                <input type="hidden" name="role" id="roleInput" value="customer">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label" for="first_name">First name</label>
                        <input type="text" class="form-control" id="first_name" name="first_name" required placeholder="Aarav">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="last_name">Last name</label>
                        <input type="text" class="form-control" id="last_name" name="last_name" required placeholder="Shrestha">
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-sm-6">
                        <label class="form-label" for="email">Email</label>
                        <input type="email" class="form-control" id="email" name="email" required placeholder="you@example.com">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="phone">Phone</label>
                        <input type="tel" class="form-control" id="phone" name="phone" placeholder="+977 98XXXXXXXX">
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label" for="password">Password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" id="password" name="password" required placeholder="At least 8 characters" minlength="8">
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password', this)"><i class="bi bi-eye"></i></button>
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label" for="confirmPassword">Confirm password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required placeholder="Re-enter password" minlength="8">
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPassword', this)"><i class="bi bi-eye"></i></button>
                    </div>
                </div>
                <button type="submit" class="btn btn-ek-primary w-100 btn-lg mt-4">Create account</button>
            </form>

            <p class="text-muted small text-center mt-4">
                Already have an account? <a href="/auth/login" class="fw-semibold">Log in</a>
            </p>
        </div>
    </div>

    <!-- Brand Panel (desktop only) -->
    <div class="ek-auth-brand d-none d-lg-flex">
        <a href="/" style="color:#fff;text-decoration:none;display:flex;align-items:center;gap:.5rem;align-self:flex-end">
            <i class="bi bi-stars" style="color:var(--ek-gold-light)"></i>
            <span class="font-display fs-4 fw-semibold">EventKraft</span>
        </a>
        <div>
            <h2>Plan your perfect day with <span class="text-gradient-gold">premium talent</span>.</h2>
            <p style="opacity:.8;max-width:400px" class="mt-3">Join hundreds of customers and event professionals trusting EventKraft.</p>
        </div>
        <p class="small" style="opacity:.5">&copy; EventKraft · Nepal</p>
    </div>
</div>

<script>
function selectRole(role) {
    document.getElementById('roleInput').value = role;
    document.getElementById('roleCustomer').classList.toggle('active', role === 'customer');
    document.getElementById('roleWorker').classList.toggle('active', role === 'worker');
}
function togglePassword(id, btn) {
    const input = document.getElementById(id);
    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    btn.querySelector('i').className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
}
</script>

<%- include('../partials/tail') %>
