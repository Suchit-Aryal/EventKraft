<%- include('../partials/header') %>

    <div class="container-fluid py-4">
        <!-- Greeting -->
        <div class="dash-greeting">
            <h2><i class="bi bi-person-circle text-info"></i> Customer Dashboard</h2>
            <p>Welcome back, <strong>
                    <%= profile ? profile.first_name : 'Customer' %>
                </strong>! Manage your jobs and bookings.</p>
        </div>

        <!-- Stat Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-2">
                <div class="stat-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-blue"><i class="bi bi-megaphone"></i></div>
                        <div>
                            <div class="stat-value">
                                <%= stats.activeJobs %>
                            </div>
                            <div class="stat-label">Active Jobs</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-orange"><i class="bi bi-envelope"></i></div>
                        <div>
                            <div class="stat-value">
                                <%= stats.pendingProposals %>
                            </div>
                            <div class="stat-label">Proposals</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-cyan"><i class="bi bi-calendar-check"></i></div>
                        <div>
                            <div class="stat-value">
                                <%= stats.activeBookings %>
                            </div>
                            <div class="stat-label">Bookings</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-green"><i class="bi bi-cash-stack"></i></div>
                        <div>
                            <div class="stat-value">NPR <%= Number(stats.totalSpent).toLocaleString() %>
                            </div>
                            <div class="stat-label">Total Spent</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-purple"><i class="bi bi-clipboard-data"></i></div>
                        <div>
                            <div class="stat-value">
                                <%= stats.totalJobs %>
                            </div>
                            <div class="stat-label">Total Posts</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <a href="/jobs/create" class="quick-action">
                    <div class="qa-icon bg-blue"><i class="bi bi-plus-circle text-white"></i></div>
                    <div><strong>Post a Job</strong><br><small class="text-muted">Find a service provider</small></div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/gigs" class="quick-action">
                    <div class="qa-icon bg-orange"><i class="bi bi-search text-white"></i></div>
                    <div><strong>Browse Services</strong><br><small class="text-muted">Find & book directly</small>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/messages" class="quick-action">
                    <div class="qa-icon bg-green"><i class="bi bi-chat-dots text-white"></i></div>
                    <div><strong>Messages</strong><br><small class="text-muted">Chat with workers</small></div>
                </a>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-pills nav-pills-crm mb-3">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="pill" href="#tab-jobs">My Jobs (<%=
                        jobs.length %>)</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="pill" href="#tab-bookings">Bookings (<%=
                        bookings.length %>)</a></li>
        </ul>

        <div class="tab-content">
            <!-- Jobs Tab -->
            <div class="tab-pane fade show active" id="tab-jobs">
                <% if (jobs.length> 0) { %>
                    <div class="crm-table bg-white">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Category</th>
                                    <th>Budget</th>
                                    <th>Proposals</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% jobs.forEach(j=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= j.title %>
                                            </strong></td>
                                        <td>
                                            <%= j.category_name || '—' %>
                                        </td>
                                        <td>NPR <%= Number(j.budget_min).toLocaleString() %> — <%=
                                                    Number(j.budget_max).toLocaleString() %>
                                        </td>
                                        <td><span class="badge bg-primary">
                                                <%= j.proposal_count %> proposals
                                            </span></td>
                                        <td><span class="badge-status badge-<%= j.status %>">
                                                <%= j.status %>
                                            </span></td>
                                        <td>
                                            <%= new Date(j.created_at).toLocaleDateString() %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="empty-state"><i class="bi bi-megaphone"></i>
                            <p>No jobs posted yet. Post your first job!</p>
                        </div>
                        <% } %>
            </div>

            <!-- Bookings Tab -->
            <div class="tab-pane fade" id="tab-bookings">
                <% if (bookings.length> 0) { %>
                    <div class="crm-table bg-white">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Worker</th>
                                    <th>Service</th>
                                    <th>Amount</th>
                                    <th>Event Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bookings.forEach(b=> { %>
                                    <tr>
                                        <td><i class="bi bi-person-circle"></i>
                                            <%= b.worker_name || 'Worker' %>
                                        </td>
                                        <td>
                                            <%= b.gig_title || b.job_title || '—' %>
                                        </td>
                                        <td>NPR <%= Number(b.total_amount).toLocaleString() %>
                                        </td>
                                        <td>
                                            <%= b.event_date ? new Date(b.event_date).toLocaleDateString() : '—' %>
                                        </td>
                                        <td><span class="badge-status badge-<%= b.status %>">
                                                <%= b.status %>
                                            </span></td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="empty-state"><i class="bi bi-calendar-check"></i>
                            <p>No bookings yet.</p>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/tail') %>