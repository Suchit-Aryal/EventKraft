<%- include('../partials/header') %>

<div class="ek-auth-split">
    <div class="ek-auth-brand d-none d-lg-flex">
        <a href="/" style="color:#fff;text-decoration:none;display:flex;align-items:center;gap:.5rem">
            <i class="bi bi-stars" style="color:var(--ek-gold-light)"></i>
            <span class="font-display fs-4 fw-semibold">EventKraft</span>
        </a>
        <div>
            <h2>Two-Factor<br>Authentication</h2>
            <p style="opacity:.8;max-width:400px" class="mt-3">Your account is protected with 2FA. Enter the code from your authenticator app to continue.</p>
        </div>
        <p class="small" style="opacity:.5">&copy; EventKraft · Nepal</p>
    </div>

    <div class="ek-auth-form">
        <div style="width:100%;max-width:400px">
            <div class="text-center mb-4">
                <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#198754,#20c997);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                    <i class="bi bi-shield-lock fs-2 text-white"></i>
                </div>
                <h1 class="font-display fs-3 fw-semibold">Authentication Code</h1>
                <p class="text-muted small">Open your authenticator app and enter the 6-digit code.</p>
            </div>

            <form action="/auth/2fa" method="POST" class="ek-form">
                <div class="mb-4">
                    <div class="d-flex gap-2 justify-content-center" id="totpInputs">
                        <input type="text" class="form-control text-center fw-bold totp-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px" autofocus>
                        <input type="text" class="form-control text-center fw-bold totp-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold totp-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold totp-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold totp-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold totp-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                    </div>
                    <input type="hidden" name="token" id="totpHidden">
                </div>
                <button type="submit" class="btn btn-ek-primary w-100 btn-lg">Verify</button>
            </form>

            <p class="text-muted small text-center mt-4">
                <a href="/auth/login" class="text-muted"><i class="bi bi-arrow-left me-1"></i>Back to login</a>
            </p>
        </div>
    </div>
</div>

<script>
(function () {
    const digits = document.querySelectorAll('.totp-digit');
    const hidden = document.getElementById('totpHidden');
    digits.forEach((input, i) => {
        input.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 1);
            if (this.value && i < digits.length - 1) digits[i + 1].focus();
            hidden.value = Array.from(digits).map(d => d.value).join('');
        });
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Backspace' && !this.value && i > 0) {
                digits[i - 1].focus(); digits[i - 1].value = '';
                hidden.value = Array.from(digits).map(d => d.value).join('');
            }
        });
        input.addEventListener('paste', function (e) {
            e.preventDefault();
            const data = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 6);
            data.split('').forEach((ch, j) => { if (digits[j]) digits[j].value = ch; });
            if (digits[Math.min(data.length, 5)]) digits[Math.min(data.length, 5)].focus();
            hidden.value = Array.from(digits).map(d => d.value).join('');
        });
    });
})();
</script>

<%- include('../partials/tail') %>
