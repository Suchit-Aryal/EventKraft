<%- include('../partials/header') %>
    <div class="container py-5">
        <h2>Admin Dashboard</h2>
        <div class="row g-4 mt-3">
            <div class="col-md-3">
                <div class="card text-center p-3 shadow-sm">
                    <h3 class="text-primary">
                        <%= stats.totalUsers %>
                    </h3>
                    <p class="text-muted mb-0">Users</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center p-3 shadow-sm">
                    <h3 class="text-primary">
                        <%= stats.totalJobs %>
                    </h3>
                    <p class="text-muted mb-0">Job Postings</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center p-3 shadow-sm">
                    <h3 class="text-primary">
                        <%= stats.totalGigs %>
                    </h3>
                    <p class="text-muted mb-0">Service Gigs</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center p-3 shadow-sm">
                    <h3 class="text-warning">
                        <%= stats.openDisputes %>
                    </h3>
                    <p class="text-muted mb-0">Open Disputes</p>
                </div>
            </div>
        </div>
        <div class="row g-3 mt-4">
            <div class="col-md-4"><a href="/admin/users" class="btn btn-outline-dark w-100">Manage Users</a></div>
            <div class="col-md-4"><a href="/admin/disputes" class="btn btn-outline-dark w-100">View Disputes</a></div>
            <div class="col-md-4"><a href="/admin/commissions" class="btn btn-outline-dark w-100">Commission
                    Settings</a></div>
        </div>
    </div>
    <%- include('../partials/tail') %>