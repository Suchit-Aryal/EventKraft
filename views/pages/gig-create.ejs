<%- include('../partials/header') %>

<section class="container py-5" style="max-width:780px">
    <div class="text-center mb-4">
        <h1 class="font-display fs-2 fw-semibold">Create a Service</h1>
        <p class="text-muted">Showcase your skills and start getting bookings.</p>
    </div>

    <!-- Progress Steps -->
    <div class="d-flex justify-content-center gap-3 mb-4">
        <div class="step-indicator active" id="step1Dot"><span>1</span> Details</div>
        <div class="step-indicator" id="step2Dot"><span>2</span> Images</div>
        <div class="step-indicator" id="step3Dot"><span>3</span> Packages</div>
    </div>

    <form action="/gigs" method="POST" enctype="multipart/form-data" id="gigForm">

        <!-- ═══ STEP 1: Service Details ═══ -->
        <div class="card shadow-sm mb-4 gig-step" id="step1">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-1-circle-fill text-primary me-2"></i>Service Details</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label" for="title">Service Title *</label>
                    <input type="text" class="form-control" id="title" name="title" required
                        placeholder="e.g. Professional Wedding Photography">
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label" for="category_id">Category *</label>
                        <select class="form-select" id="category_id" name="category_id" required>
                            <option value="" disabled selected>Select a category</option>
                            <% categories.forEach(function(c) { %>
                                <option value="<%= c.id %>"><%= c.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="starting_price">Starting Price (NPR) *</label>
                        <input type="number" class="form-control" id="starting_price" name="starting_price" required
                            min="100" step="100" placeholder="e.g. 25000">
                        <div class="form-text">Base price shown in search results.</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="description">Description *</label>
                    <textarea class="form-control" id="description" name="description" rows="5" required
                        placeholder="Describe your service, experience, what's included…"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="delivery_time">Delivery Time</label>
                    <input type="text" class="form-control" id="delivery_time" name="delivery_time"
                        placeholder="e.g. 3-7 days">
                </div>
                <div class="text-end">
                    <button type="button" class="btn btn-primary" onclick="goToStep(2)">Next: Add Images <i class="bi bi-arrow-right"></i></button>
                </div>
            </div>
        </div>

        <!-- ═══ STEP 2: Portfolio Images ═══ -->
        <div class="card shadow-sm mb-4 gig-step gig-step-hidden" id="step2">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-2-circle-fill text-primary me-2"></i>Portfolio Images</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Upload up to 5 images of your previous work. Customers will see these on your service page. (JPG, PNG, WebP — max 5MB each)</p>

                <!-- Drop Zone -->
                <div id="dropZone" class="border border-2 border-dashed rounded-3 p-4 text-center"
                    style="cursor:pointer; transition: all 0.2s; border-color: #dee2e6;">
                    <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                    <p class="text-muted mb-1">Drag & drop images here or click to browse</p>
                    <p class="text-muted small mb-0">Up to 5 images (JPG, PNG, WebP)</p>
                    <input type="file" id="imageInput" name="portfolio_images" multiple
                        accept="image/jpeg,image/png,image/webp" class="d-none">
                </div>

                <!-- Preview Grid -->
                <div id="imagePreview" class="row g-2 mt-2"></div>

                <div class="d-flex justify-content-between mt-3">
                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(1)"><i class="bi bi-arrow-left"></i> Back</button>
                    <button type="button" class="btn btn-primary" onclick="goToStep(3)">Next: Pricing Packages <i class="bi bi-arrow-right"></i></button>
                </div>
            </div>
        </div>

        <!-- ═══ STEP 3: Pricing Tiers ═══ -->
        <div class="card shadow-sm mb-4 gig-step gig-step-hidden" id="step3">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-3-circle-fill text-primary me-2"></i>Pricing Packages <span class="badge bg-secondary ms-1">Optional</span></h5>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="enableTiers" style="cursor:pointer">
                    <label class="form-check-label small" for="enableTiers" style="cursor:pointer">Add packages</label>
                </div>
            </div>
            <div class="card-body">
                <!-- Help text when tiers are off -->
                <div id="tiersHelp">
                    <div class="text-center py-4">
                        <i class="bi bi-boxes fs-1 text-muted"></i>
                        <p class="text-muted mt-2 mb-1">Want to offer different pricing options?</p>
                        <p class="text-muted small">Toggle the switch above to add <strong>Basic</strong>, <strong>Standard</strong>, and <strong>Premium</strong> packages with different features and prices.</p>
                    </div>
                </div>

                <!-- Tier Cards (shown when toggle is on) -->
                <div id="tiersSection" style="display:none">
                    <p class="text-muted small mb-3">Define packages to give customers options. Each package can have its own price, features, and delivery time.</p>

                    <!-- Tier Tabs -->
                    <ul class="nav nav-pills nav-fill mb-3" id="tierTabs">
                        <li class="nav-item">
                            <button class="nav-link active" type="button" data-tier="basic" onclick="showTier('basic')">
                                <i class="bi bi-star me-1"></i>Basic
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" type="button" data-tier="standard" onclick="showTier('standard')">
                                <i class="bi bi-star-half me-1"></i>Standard
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" type="button" data-tier="premium" onclick="showTier('premium')">
                                <i class="bi bi-star-fill me-1"></i>Premium
                            </button>
                        </li>
                    </ul>

                    <!-- Basic Tier -->
                    <div class="tier-panel" id="tierBasic">
                        <input type="hidden" name="pkg_tier" value="basic" class="tier-hidden" disabled>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small">Package Title *</label>
                                <input type="text" class="form-control tier-input" name="pkg_title" placeholder="e.g. Starter Package" disabled>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Price (NPR) *</label>
                                <input type="number" class="form-control tier-input" name="pkg_price" min="100" step="100" placeholder="5000" disabled>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Delivery</label>
                                <input type="text" class="form-control tier-input" name="pkg_delivery_time" placeholder="3 days" disabled>
                            </div>
                            <div class="col-12">
                                <label class="form-label small">Description</label>
                                <textarea class="form-control tier-input" name="pkg_description" rows="2" placeholder="What's included in this tier…" disabled></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small">Features <span class="text-muted">(comma-separated)</span></label>
                                <input type="text" class="form-control tier-input" name="pkg_features" placeholder="e.g. 50 photos, Basic editing, Digital delivery" disabled>
                            </div>
                        </div>
                    </div>

                    <!-- Standard Tier -->
                    <div class="tier-panel d-none" id="tierStandard">
                        <input type="hidden" name="pkg_tier" value="standard" class="tier-hidden" disabled>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small">Package Title *</label>
                                <input type="text" class="form-control tier-input" name="pkg_title" placeholder="e.g. Professional Package" disabled>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Price (NPR) *</label>
                                <input type="number" class="form-control tier-input" name="pkg_price" min="100" step="100" placeholder="15000" disabled>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Delivery</label>
                                <input type="text" class="form-control tier-input" name="pkg_delivery_time" placeholder="5 days" disabled>
                            </div>
                            <div class="col-12">
                                <label class="form-label small">Description</label>
                                <textarea class="form-control tier-input" name="pkg_description" rows="2" placeholder="What's included…" disabled></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small">Features <span class="text-muted">(comma-separated)</span></label>
                                <input type="text" class="form-control tier-input" name="pkg_features" placeholder="e.g. 150 photos, Advanced editing, Album" disabled>
                            </div>
                        </div>
                    </div>

                    <!-- Premium Tier -->
                    <div class="tier-panel d-none" id="tierPremium">
                        <input type="hidden" name="pkg_tier" value="premium" class="tier-hidden" disabled>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small">Package Title *</label>
                                <input type="text" class="form-control tier-input" name="pkg_title" placeholder="e.g. VIP Package" disabled>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Price (NPR) *</label>
                                <input type="number" class="form-control tier-input" name="pkg_price" min="100" step="100" placeholder="50000" disabled>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Delivery</label>
                                <input type="text" class="form-control tier-input" name="pkg_delivery_time" placeholder="7 days" disabled>
                            </div>
                            <div class="col-12">
                                <label class="form-label small">Description</label>
                                <textarea class="form-control tier-input" name="pkg_description" rows="2" placeholder="What's included…" disabled></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small">Features <span class="text-muted">(comma-separated)</span></label>
                                <input type="text" class="form-control tier-input" name="pkg_features" placeholder="e.g. Unlimited photos, Drone shots, Premium album" disabled>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(2)"><i class="bi bi-arrow-left"></i> Back</button>
                    <input type="hidden" name="status" value="active">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-lg me-1"></i> Publish Service
                    </button>
                    <button type="submit" name="status" value="draft" class="btn btn-outline-secondary btn-lg">
                        Save as Draft
                    </button>
                    <a href="/auth/dashboard" class="btn btn-outline-danger btn-lg ms-auto">Cancel</a>
                </div>
            </div>
        </div>

    </form>
</section>

<style>
    .step-indicator { display:flex; align-items:center; gap:.4rem; font-size:.85rem; color:#aaa; font-weight:500; }
    .step-indicator span { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; background:#eee; color:#999; font-weight:700; font-size:.8rem; }
    .step-indicator.active { color:var(--bs-primary, #0d6efd); }
    .step-indicator.active span { background:var(--bs-primary, #0d6efd); color:#fff; }
    .step-indicator.done { color:#198754; }
    .step-indicator.done span { background:#198754; color:#fff; }
    .gig-step-hidden { height:0; overflow:hidden; margin:0 !important; padding:0 !important; border:none !important; box-shadow:none !important; opacity:0; position:absolute; pointer-events:none; }
    #dropZone.dragover { border-color: var(--bs-primary) !important; background: rgba(13, 110, 253, 0.04); }
    .img-preview-card { position:relative; border-radius:8px; overflow:hidden; }
    .img-preview-card img { width:100%; height:120px; object-fit:cover; border-radius:8px; }
    .img-preview-card .remove-btn { position:absolute; top:4px; right:4px; width:24px; height:24px; padding:0; border-radius:50%; background:rgba(220,53,69,0.9); color:#fff; border:none; font-size:14px; line-height:24px; cursor:pointer; }
    .tier-panel { padding:1rem; background:#f8f9fa; border-radius:8px; }
    #tierTabs .nav-link { font-size:.85rem; }
    #tierTabs .nav-link.active { background:var(--bs-primary, #0d6efd); color:#fff; }
</style>

<script>
(function () {
    // ── Step Navigation ─────────────────────────────
    window.goToStep = function(step) {
        document.querySelectorAll('.gig-step').forEach(el => {
            el.classList.add('gig-step-hidden');
        });
        document.getElementById('step' + step).classList.remove('gig-step-hidden');

        // Update dots
        for (let i = 1; i <= 3; i++) {
            const dot = document.getElementById('step' + i + 'Dot');
            dot.classList.remove('active', 'done');
            if (i < step) dot.classList.add('done');
            else if (i === step) dot.classList.add('active');
        }

        window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    // Handle form submit — show all steps so browser validation works
    document.getElementById('gigForm').addEventListener('submit', function(e) {
        document.querySelectorAll('.gig-step').forEach(el => el.classList.remove('gig-step-hidden'));
    });

    // ── Image Upload ────────────────────────────────
    const dropZone = document.getElementById('dropZone');
    const imageInput = document.getElementById('imageInput');
    const previewGrid = document.getElementById('imagePreview');
    const MAX_FILES = 5;
    let fileStore = new DataTransfer();

    dropZone.addEventListener('click', () => imageInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
    dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('dragover'); addFiles(e.dataTransfer.files); });
    imageInput.addEventListener('change', () => addFiles(imageInput.files));

    function addFiles(newFiles) {
        for (const file of newFiles) {
            if (fileStore.files.length >= MAX_FILES) break;
            if (!file.type.startsWith('image/')) continue;
            fileStore.items.add(file);
        }
        imageInput.files = fileStore.files;
        renderPreviews();
    }

    function removeFile(index) {
        const newStore = new DataTransfer();
        for (let i = 0; i < fileStore.files.length; i++) {
            if (i !== index) newStore.items.add(fileStore.files[i]);
        }
        fileStore = newStore;
        imageInput.files = fileStore.files;
        renderPreviews();
    }

    function renderPreviews() {
        previewGrid.innerHTML = '';
        for (let i = 0; i < fileStore.files.length; i++) {
            const file = fileStore.files[i];
            const col = document.createElement('div'); col.className = 'col-4 col-md-2';
            const card = document.createElement('div'); card.className = 'img-preview-card';
            const img = document.createElement('img'); img.src = URL.createObjectURL(file); img.alt = file.name;
            const btn = document.createElement('button'); btn.type = 'button'; btn.className = 'remove-btn'; btn.innerHTML = '&times;'; btn.onclick = () => removeFile(i);
            card.appendChild(img); card.appendChild(btn); col.appendChild(card); previewGrid.appendChild(col);
        }
        const remaining = MAX_FILES - fileStore.files.length;
        dropZone.querySelector('p:first-of-type').textContent = fileStore.files.length > 0
            ? `${fileStore.files.length} image${fileStore.files.length > 1 ? 's' : ''} selected` + (remaining > 0 ? ` — ${remaining} more allowed` : '')
            : 'Drag & drop images here or click to browse';
    }

    // ── Tier Toggle & Tabs ──────────────────────────
    const tiersToggle = document.getElementById('enableTiers');
    const tiersSection = document.getElementById('tiersSection');
    const tiersHelp = document.getElementById('tiersHelp');

    tiersToggle.addEventListener('change', function () {
        tiersSection.style.display = this.checked ? 'block' : 'none';
        tiersHelp.style.display = this.checked ? 'none' : 'block';
        document.querySelectorAll('.tier-input').forEach(el => el.disabled = !this.checked);
        document.querySelectorAll('.tier-hidden').forEach(el => el.disabled = !this.checked);
    });

    window.showTier = function(tier) {
        document.querySelectorAll('.tier-panel').forEach(p => p.classList.add('d-none'));
        document.getElementById('tier' + tier.charAt(0).toUpperCase() + tier.slice(1)).classList.remove('d-none');
        document.querySelectorAll('#tierTabs .nav-link').forEach(b => {
            b.classList.toggle('active', b.dataset.tier === tier);
        });
    };
})();
</script>

<%- include('../partials/tail') %>