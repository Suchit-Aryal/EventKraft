<%- include('../partials/header') %>

<div class="ek-auth-split">
    <div class="ek-auth-brand d-none d-lg-flex">
        <a href="/" style="color:#fff;text-decoration:none;display:flex;align-items:center;gap:.5rem">
            <i class="bi bi-stars" style="color:var(--ek-gold-light)"></i>
            <span class="font-display fs-4 fw-semibold">EventKraft</span>
        </a>
        <div>
            <h2>Almost there!</h2>
            <p style="opacity:.8;max-width:400px" class="mt-3">We sent a 6-digit verification code to your email. Enter it below to activate your account.</p>
        </div>
        <p class="small" style="opacity:.5">&copy; EventKraft · Nepal</p>
    </div>

    <div class="ek-auth-form">
        <div style="width:100%;max-width:400px">
            <div class="text-center mb-4">
                <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                    <i class="bi bi-envelope-check fs-2 text-white"></i>
                </div>
                <h1 class="font-display fs-3 fw-semibold">Verify your email</h1>
                <p class="text-muted small">Enter the 6-digit code we sent to your email address.</p>
            </div>

            <form action="/auth/verify" method="POST" class="ek-form">
                <div class="mb-4">
                    <div class="d-flex gap-2 justify-content-center" id="codeInputs">
                        <input type="text" class="form-control text-center fw-bold code-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px" autofocus>
                        <input type="text" class="form-control text-center fw-bold code-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold code-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold code-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold code-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                        <input type="text" class="form-control text-center fw-bold code-digit" maxlength="1" style="width:48px;height:56px;font-size:24px;border-radius:12px">
                    </div>
                    <input type="hidden" name="code" id="codeHidden">
                </div>
                <button type="submit" class="btn btn-ek-primary w-100 btn-lg">Verify Email</button>
            </form>

            <div class="text-center mt-4">
                <p class="text-muted small mb-2">Didn't receive the code?</p>
                <form action="/auth/verify/resend" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-link btn-sm p-0 fw-semibold">Resend code</button>
                </form>
            </div>

            <p class="text-muted small text-center mt-4">
                <a href="/auth/login" class="text-muted"><i class="bi bi-arrow-left me-1"></i>Back to login</a>
            </p>
        </div>
    </div>
</div>

<script>
(function () {
    const digits = document.querySelectorAll('.code-digit');
    const hidden = document.getElementById('codeHidden');
    digits.forEach((input, i) => {
        input.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 1);
            if (this.value && i < digits.length - 1) digits[i + 1].focus();
            updateHidden();
        });
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Backspace' && !this.value && i > 0) {
                digits[i - 1].focus(); digits[i - 1].value = ''; updateHidden();
            }
        });
        input.addEventListener('paste', function (e) {
            e.preventDefault();
            const data = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 6);
            data.split('').forEach((ch, j) => { if (digits[j]) digits[j].value = ch; });
            if (digits[Math.min(data.length, 5)]) digits[Math.min(data.length, 5)].focus();
            updateHidden();
        });
    });
    function updateHidden() {
        hidden.value = Array.from(digits).map(d => d.value).join('');
    }
})();
</script>

<%- include('../partials/tail') %>
