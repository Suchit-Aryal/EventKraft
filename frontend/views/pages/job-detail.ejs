<%- include('../partials/header') %>

<section class="container py-4">
    <a href="/jobs" class="text-decoration-none text-muted small d-inline-flex align-items-center gap-1 mb-3">
        <i class="bi bi-arrow-left"></i> Back to jobs
    </a>

    <div class="row g-4">
        <!-- Main -->
        <div class="col-lg-8">
            <div class="ek-card" style="padding:1.5rem 2rem">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <span class="ek-badge ek-badge-category"><%= job.category_name || 'General' %></span>
                    <% if (job.event_type) { %><span class="ek-badge" style="background:var(--ek-cream-dark)"><%= job.event_type %></span><% } %>
                    <span class="badge-status badge-<%= job.status %> ms-auto"><%= job.status %></span>
                </div>
                <h1 class="font-display fs-3 fw-semibold" style="line-height:1.3"><%= job.title %></h1>
                <div class="d-flex flex-wrap gap-3 mt-3" style="font-size:.85rem;color:var(--ek-text-muted)">
                    <span><i class="bi bi-geo-alt me-1"></i><%= job.event_location || 'Nepal' %></span>
                    <% if (job.event_date) { %>
                        <span><i class="bi bi-calendar3 me-1"></i><%= new Date(job.event_date).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'}) %></span>
                    <% } %>
                    <span><i class="bi bi-people me-1"></i><%= job.proposal_count || 0 %> proposals</span>
                </div>
                <hr style="border-color:var(--ek-border)">
                <h5 class="fw-semibold mb-2">Description</h5>
                <p class="text-muted" style="white-space:pre-line;line-height:1.7"><%= job.description %></p>
                <% if (job.special_requirements) { %>
                    <h5 class="fw-semibold mb-2 mt-4">Special Requirements</h5>
                    <p class="text-muted"><%= job.special_requirements %></p>
                <% } %>
            </div>

            <!-- Proposal Form (workers only) -->
            <% if (currentUser && currentUser.role === 'worker') { %>
                <div class="ek-card mt-4" style="padding:1.5rem 2rem">
                    <h3 class="font-display fs-5 fw-semibold mb-3">Submit your proposal</h3>
                    <form action="/jobs/<%= job.id %>/proposals" method="POST" class="ek-form">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="proposed_price">Your bid (NPR)</label>
                                <input type="number" class="form-control" id="proposed_price" name="proposed_price" required min="1000" placeholder="<%= job.budget_min || 50000 %>">
                                <small class="text-muted">Budget: NPR <%= Number(job.budget_min||0).toLocaleString('en-IN') %> – <%= Number(job.budget_max||0).toLocaleString('en-IN') %></small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="estimated_duration">Estimated duration</label>
                                <input type="text" class="form-control" id="estimated_duration" name="estimated_duration" placeholder="e.g. 3 days">
                            </div>
                        </div>
                        <div class="mt-3">
                            <label class="form-label" for="cover_letter">Cover letter</label>
                            <textarea class="form-control" id="cover_letter" name="cover_letter" rows="5" required placeholder="Tell the customer why you're the perfect fit…"></textarea>
                        </div>
                        <button type="submit" class="btn btn-ek-primary mt-3">Send proposal</button>
                    </form>
                </div>
            <% } %>

            <!-- Proposals list (job owner only) -->
            <% if (typeof proposals !== 'undefined' && proposals.length > 0) { %>
                <div class="mt-4">
                    <h3 class="font-display fs-5 fw-semibold mb-3"><%= proposals.length %> proposal<%= proposals.length===1?'':'s' %></h3>
                    <% proposals.forEach(function(p) { %>
                        <div class="ek-card mb-3" style="padding:1.25rem">
                            <div class="d-flex gap-3">
                                <img src="<%= p.worker_avatar || ('https://ui-avatars.com/api/?name='+(p.worker_first_name||'U')) %>" alt="" style="width:48px;height:48px;border-radius:50%;object-fit:cover">
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between flex-wrap gap-2">
                                        <strong><%= p.worker_first_name %> <%= p.worker_last_name || '' %></strong>
                                        <span class="fw-bold" style="color:var(--ek-maroon)">NPR <%= Number(p.proposed_price).toLocaleString('en-IN') %></span>
                                    </div>
                                    <small class="text-muted">★ <%= p.worker_rating || 0 %> · <%= p.worker_completed || 0 %> completed</small>
                                    <p class="text-muted small mt-2 mb-0"><%= p.cover_letter %></p>
                                    <span class="badge-status badge-<%= p.status %> mt-2 d-inline-block"><%= p.status %></span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="ek-card" style="padding:1.5rem">
                <p class="text-muted small text-uppercase fw-bold mb-1" style="letter-spacing:.5px">Budget</p>
                <p class="font-display fs-3 fw-semibold mb-0">NPR <%= Number(job.budget_min||0).toLocaleString('en-IN') %> – <%= Number(job.budget_max||0).toLocaleString('en-IN') %></p>
                <hr style="border-color:var(--ek-border)">
                <p class="text-muted small mb-1">Posted by</p>
                <p class="fw-semibold mb-0"><%= job.customer_first_name || 'Customer' %> <%= job.customer_last_name || '' %></p>
            </div>
            <div class="ek-card mt-3" style="padding:1.5rem;background:var(--ek-gradient-subtle)">
                <h6 class="fw-semibold mb-2">Tips for a winning proposal</h6>
                <ul class="small text-muted ps-3 mb-0">
                    <li class="mb-1">Reference the customer's specific needs</li>
                    <li class="mb-1">Show a relevant portfolio link</li>
                    <li class="mb-1">Be transparent about pricing</li>
                    <li>Reply within 24 hours</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/tail') %>