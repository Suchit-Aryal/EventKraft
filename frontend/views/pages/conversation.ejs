<%- include('../partials/header') %>

<div class="container py-4">
    <a href="/messages" class="text-decoration-none text-muted small d-inline-flex align-items-center gap-1 mb-3"><i class="bi bi-arrow-left"></i> Back to messages</a>

    <div class="ek-card" style="max-width:800px;margin:0 auto">
        <!-- Header -->
        <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--ek-border)" class="d-flex align-items-center gap-3">
            <img src="<%= otherAvatar || 'https://ui-avatars.com/api/?name=U' %>" alt="" style="width:40px;height:40px;border-radius:50%;object-fit:cover">
            <strong><%= otherName || 'User' %></strong>
        </div>

        <!-- Messages -->
        <div id="messageArea" style="height:400px;overflow-y:auto;padding:1rem 1.25rem">
            <% messages.forEach(function(m) { %>
                <div class="ek-chat-bubble <%= m.sender_id === currentUser.id ? 'sent' : 'received' %>">
                    <p class="mb-0"><%= m.content %></p>
                    <small style="opacity:.6;font-size:.7rem"><%= new Date(m.created_at).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}) %></small>
                </div>
            <% }); %>
        </div>

        <!-- Send -->
        <form action="/messages/<%= conversation.id %>/send" method="POST" style="padding:1rem 1.25rem;border-top:1px solid var(--ek-border)" class="d-flex gap-2">
            <input type="hidden" name="receiver_id" value="<%= conversation.participant_1 === currentUser.id ? conversation.participant_2 : conversation.participant_1 %>">
            <input type="text" name="content" class="form-control" placeholder="Type a message…" required autocomplete="off" style="border-radius:50px">
            <button type="submit" class="btn btn-ek-primary" style="border-radius:50px;padding:.5rem 1.25rem"><i class="bi bi-send"></i></button>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var area = document.getElementById('messageArea');
    if (area) area.scrollTop = area.scrollHeight;
});
</script>

<%- include('../partials/tail') %>