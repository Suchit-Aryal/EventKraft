<%- include('../partials/header') %>
    <div class="container py-5">
        <h2 class="mb-4"><i class="bi bi-star"></i> Reviews</h2>

        <% if (reviews && reviews.length> 0) { %>
            <% reviews.forEach(r=> { %>
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="d-flex align-items-center gap-3">
                                <% if (r.reviewer_avatar) { %>
                                    <img src="<%= r.reviewer_avatar %>" class="rounded-circle" width="40" height="40"
                                        alt="avatar">
                                    <% } else { %>
                                        <i class="bi bi-person-circle fs-3"></i>
                                        <% } %>
                                            <div>
                                                <strong>
                                                    <%= r.reviewer_first_name || 'Anonymous' %>
                                                        <%= r.reviewer_last_name || '' %>
                                                </strong>
                                                <div class="stars">
                                                    <% for(let i=1; i <=5; i++) { %>
                                                        <i
                                                            class="bi bi-star<%= i <= r.rating ? '-fill text-warning' : '' %>"></i>
                                                        <% } %>
                                                            <span class="ms-1 text-muted small">(<%= r.rating %>
                                                                    /5)</span>
                                                </div>
                                            </div>
                            </div>
                            <small class="text-muted">
                                <%= new Date(r.created_at).toLocaleDateString() %>
                            </small>
                        </div>

                        <p class="mt-3 mb-0">
                            <%= r.comment || 'No comment provided.' %>
                        </p>

                        <% if (r.response) { %>
                            <div class="bg-light p-3 rounded mt-3">
                                <strong class="small text-muted"><i class="bi bi-reply"></i> Worker Response:</strong>
                                <p class="mb-0 small">
                                    <%= r.response %>
                                </p>
                            </div>
                            <% } %>
                    </div>
                </div>
                <% }) %>
                    <% } else { %>
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-star fs-1"></i>
                            <p>No reviews yet.</p>
                        </div>
                        <% } %>
    </div>
    <%- include('../partials/tail') %>